{
    "name": "serverless_mud",
    "version": "0.0.1",
    "copyright": "&copy; 2026 Adrian Hall",
    "description": "A simple MUD game built on Cloudflare Workers",
    "license": "MIT",
    "packageManager": "pnpm@10.33.2",
    "private": true,
    "type": "module",
    "scripts": {
        "prebuild": "run-s generate:types",
        "build": "vite build",
        "check": "run-s check:prettier check:types check:eslint test:coverage",
        "check:prettier": "prettier --check ./src",
        "check:types": "tsc --noEmit",
        "check:eslint": "eslint src/ tests/",
        "clean": "rimraf .wrangler dist coverage worker-configuration.d.ts",
        "predeploy": "run-s generate:world db:migrate:remote build",
        "deploy": "wrangler deploy",
        "predev": "run-s generate:world db:migrate:local generate:types",
        "dev": "vite dev",
        "db:migrate:local": "wrangler d1 migrations apply MAP --local",
        "db:migrate:remote": "wrangler d1 migrations apply MAP --remote",
        "format": "run-s format:code",
        "format:code": "prettier --write ./src",
        "generate:types": "wrangler types",
        "generate:world": "run-s generate:world:json generate:world:sql",
        "generate:world:json": "tsx src/tools/generate-world/index.ts",
        "generate:world:sql": "tsx src/tools/generate-world-sql/index.ts",
        "preview": "vite preview",
        "test": "vitest run",
        "test:coverage": "vitest run --coverage"
    },
    "dependencies": {
        "@adrianhall/cloudflare-auth": "github:adrianhall/cloudflare-auth",
        "chalk": "^5.6.2",
        "commander": "^14.0.3",
        "hono": "^4.12.16",
        "react": "^19.1.0",
        "react-dom": "^19.1.0"
    },
    "devDependencies": {
        "@cloudflare/vite-plugin": "^1.0.0",
        "@cloudflare/vitest-pool-workers": "^0.15.1",
        "@eslint/js": "^9.39.4",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "@vitejs/plugin-react": "^4.5.0",
        "@vitest/coverage-istanbul": "^4.1.5",
        "eslint": "^9.39.4",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "globals": "^17.5.0",
        "happy-dom": "^20.9.0",
        "npm-run-all2": "^8.0.4",
        "prettier": "^3.8.3",
        "rimraf": "^6.1.3",
        "tsx": "^4.21.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.59.1",
        "vite": "^6.3.0",
        "vitest": "^4.1.5",
        "wrangler": "^4.86.0"
    },
    "pnpm": {
        "onlyBuiltDependencies": [
            "@adrianhall/cloudflare-auth",
            "esbuild",
            "sharp",
            "workerd"
        ]
    },
    "prettier": {
        "arrowParens": "always",
        "bracketSameLine": false,
        "bracketSpacing": true,
        "checkIgnorePragma": true,
        "endOfLine": "lf",
        "experimentalTernaries": true,
        "experimentalOperatorPosition": "start",
        "htmlWhitespaceSensitivity": "css",
        "jsxSingleQuote": false,
        "objectWrap": "preserve",
        "printWidth": 100,
        "quoteProps": "consistent",
        "tabWidth": 2,
        "semi": true,
        "singleQuote": false,
        "trailingComma": "none"
    }
}
