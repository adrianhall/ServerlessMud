# Cloudflare API token used by Terraform and the validation scripts.
# Create at: https://dash.cloudflare.com/profile/api-tokens
# Required permissions:
# - Account: Workers Scripts: Edit
# - Account: D1: Edit
# - Account: Workers KV Storage: Edit
# - Account: Access: Apps and Policies : Edit
CLOUDFLARE_API_TOKEN=

# Cloudflare account identifier for all resources in this demo.
# Find it in the Cloudflare dashboard under Account Home.
CLOUDFLARE_ACCOUNT_ID=

# Your workers.dev subdomain without the trailing ".workers.dev".
# Example: if your Worker URL is https://demo-example.workers.dev, set this to demo-example.
WORKERS_DEV_SUBDOMAIN=

# Your Cloiudflare Zero Trust Team domain. 
# Find it in the Cloudflare dashboard under Zero Trust > Settings.
CLOUDFLARE_TEAM_DOMAIN=

# Identity Provider ID for One-time PIN authentication.
# See the "Authentication" section in README.md for setup instructions.
CLOUDFLARE_ACCESS_IDP_ID=

# Prefix used to name all demo infrastructure resources.
# Worker name:            <RESOURCE_PREFIX>
# D1 database name:       <RESOURCE_PREFIX>-db
# Workers KV namespace:   <RESOURCE_PREFIX>-kv
RESOURCE_PREFIX=mud

# Common tag applied to taggable resources.
RESOURCE_TAG=mud
